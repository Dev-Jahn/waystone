{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "waystone-project-policy-1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "policies"],
  "properties": {
    "schema": {"const": "waystone-project-policy-1"},
    "policies": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "rule", "stage", "params", "summary"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"},
          "rule": {"type": "string"},
          "stage": {"enum": ["observing", "warning", "enforce"]},
          "params": {"type": "object"},
          "summary": {"type": "string", "minLength": 1, "pattern": "^[^\\r\\n]+$"}
        },
        "oneOf": [
          {
            "properties": {
              "rule": {
                "enum": [
                  "delegation-verification-evidence-v1",
                  "delegation-scope-drift-v1",
                  "env-manifest-mutation-v1",
                  "done-without-evidence-v1"
                ]
              },
              "params": {"type": "object", "maxProperties": 0}
            }
          },
          {
            "properties": {
              "rule": {"const": "objective-first-advisory-v1"},
              "params": {
                "type": "object",
                "additionalProperties": false,
                "required": ["severities"],
                "properties": {
                  "severities": {
                    "type": "array",
                    "minItems": 1,
                    "uniqueItems": true,
                    "items": {"enum": ["blocker", "major", "minor"]}
                  }
                }
              }
            }
          },
          {
            "properties": {
              "rule": {"const": "project-direction-may-be-stale-v1"},
              "params": {
                "type": "object",
                "additionalProperties": false,
                "required": ["consecutive", "diff_files_threshold", "open_blocker_threshold"],
                "properties": {
                  "consecutive": {"type": "integer", "minimum": 1},
                  "diff_files_threshold": {"type": "integer", "minimum": 1},
                  "open_blocker_threshold": {"type": "integer", "minimum": 1}
                }
              }
            }
          }
        ]
      }
    }
  }
}
