{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "waystone-profile-1",
  "type": "object",
  "required": ["bindings"],
  "additionalProperties": false,
  "properties": {
    "schema": {
      "oneOf": [
        {"const": "waystone-profile-1"},
        {"const": "jw-profile-1", "deprecated": true},
        {"type": "null", "deprecated": true}
      ]
    },
    "bindings": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": false,
      "properties": {
        "main": {"$ref": "#/$defs/main"},
        "orchestrator": {"$ref": "#/$defs/orchestrator"},
        "implementer": {"$ref": "#/$defs/implementer"},
        "clerk": {"$ref": "#/$defs/clerk"},
        "verifier": {"$ref": "#/$defs/verifier"},
        "reviewer": {"$ref": "#/$defs/reviewer"}
      }
    }
  },
  "$defs": {
    "binding": {
      "type": "object",
      "required": ["backend"],
      "additionalProperties": false,
      "properties": {
        "execution": {
          "oneOf": [
            {
              "enum": [
                "main-session",
                "clean-subagent",
                "forked-subagent",
                "deterministic-workflow",
                "external-runner"
              ]
            },
            {
              "enum": ["codex-cli", "codex-companion"],
              "deprecated": true
            }
          ]
        },
        "backend": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*:[^\\s:]+$"
        },
        "use_for": {"type": "string", "minLength": 1, "pattern": "^[^\\r\\n]+$"},
        "effort": {"enum": ["none", "minimal", "low", "medium", "high", "xhigh"]},
        "entry": {"type": "string"}
      }
    },
    "main": {
      "allOf": [
        {"$ref": "#/$defs/binding"},
        {"required": ["execution"], "properties": {"execution": {"const": "main-session"}}}
      ]
    },
    "orchestrator": {
      "allOf": [
        {"$ref": "#/$defs/binding"},
        {"required": ["execution"], "properties": {"execution": {"enum": [
          "main-session", "clean-subagent", "forked-subagent", "deterministic-workflow"
        ]}}}
      ]
    },
    "implementer": {
      "allOf": [
        {"$ref": "#/$defs/binding"},
        {"required": ["execution"], "properties": {"execution": {"enum": [
          "clean-subagent", "forked-subagent", "deterministic-workflow", "external-runner"
        ]}}}
      ]
    },
    "clerk": {
      "allOf": [
        {"$ref": "#/$defs/binding"},
        {"required": ["execution"], "properties": {"execution": {"enum": [
          "clean-subagent", "forked-subagent", "deterministic-workflow", "external-runner"
        ]}}}
      ]
    },
    "verifier": {
      "oneOf": [
        {
          "allOf": [
            {"$ref": "#/$defs/binding"},
            {"properties": {"execution": {"enum": [
              "clean-subagent", "forked-subagent", "deterministic-workflow", "external-runner"
            ]}}}
          ]
        },
        {
          "allOf": [
            {"$ref": "#/$defs/binding"},
            {"required": ["execution"], "properties": {"execution": {
              "enum": ["codex-cli", "codex-companion"],
              "deprecated": true
            }}}
          ]
        }
      ]
    },
    "reviewer": {
      "allOf": [
        {"$ref": "#/$defs/binding"},
        {"required": ["execution"], "properties": {"execution": {"enum": [
          "clean-subagent", "forked-subagent", "deterministic-workflow", "external-runner"
        ]}}}
      ]
    }
  }
}
