{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "waystone-profile-2",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "bindings"],
  "properties": {
    "schema": {"const": "waystone-profile-2"},
    "bindings": {
      "type": "object",
      "additionalProperties": false,
      "required": ["coordinator", "worker", "verifier", "reviewer"],
      "properties": {
        "coordinator": {"$ref": "#/$defs/binding"},
        "worker": {"$ref": "#/$defs/binding"},
        "verifier": {"$ref": "#/$defs/binding"},
        "reviewer": {"$ref": "#/$defs/binding"}
      }
    }
  },
  "$defs": {
    "binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["execution", "backend"],
      "properties": {
        "execution": {"enum": ["in-session", "subagent", "external"]},
        "backend": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*:[^\\s:]+$"}
      }
    }
  }
}
